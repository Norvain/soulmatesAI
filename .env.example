# MiniMax M2-her API Key: for text chat (pay-per-use)
# Get from https://platform.minimaxi.com
MINIMAX_M2HER_API_KEY="YOUR_M2HER_API_KEY"

# MiniMax API Key: for image generation
MINIMAX_API_KEY="YOUR_MINIMAX_API_KEY"

# JWT Secret: Used to sign authentication tokens.
JWT_SECRET="change-me-to-a-random-secret"

# Local FunASR speech-recognition service (see asr-service/).
# Defaults to http://127.0.0.1:8000 when unset.
ASR_SERVICE_URL="http://127.0.0.1:8000"
